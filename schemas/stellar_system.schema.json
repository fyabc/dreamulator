{
  "$defs": {
    "LuminosityClass": {
      "description": "Morgan–Keenan luminosity class.",
      "enum": [
        "Ia",
        "Ib",
        "II",
        "III",
        "IV",
        "V"
      ],
      "title": "LuminosityClass",
      "type": "string"
    },
    "OrbitalElements": {
      "description": "Keplerian orbital elements for a body orbiting another body.",
      "properties": {
        "body_id": {
          "description": "ID of the orbiting body",
          "title": "Body Id",
          "type": "string"
        },
        "parent_id": {
          "description": "ID of the central body being orbited",
          "title": "Parent Id",
          "type": "string"
        },
        "semi_major_axis_au": {
          "description": "Distance in astronomical units",
          "exclusiveMinimum": 0,
          "title": "Semi Major Axis Au",
          "type": "number"
        },
        "eccentricity": {
          "description": "Orbital eccentricity (0 = circle)",
          "exclusiveMaximum": 1,
          "minimum": 0,
          "title": "Eccentricity",
          "type": "number"
        },
        "inclination_deg": {
          "default": 0,
          "description": "Orbital inclination",
          "maximum": 180,
          "minimum": 0,
          "title": "Inclination Deg",
          "type": "number"
        },
        "longitude_ascending_node_deg": {
          "default": 0,
          "description": "Longitude of ascending node",
          "maximum": 360,
          "minimum": 0,
          "title": "Longitude Ascending Node Deg",
          "type": "number"
        },
        "argument_of_periapsis_deg": {
          "default": 0,
          "description": "Argument of periapsis",
          "maximum": 360,
          "minimum": 0,
          "title": "Argument Of Periapsis Deg",
          "type": "number"
        },
        "mean_anomaly_epoch_deg": {
          "default": 0,
          "description": "Mean anomaly at epoch",
          "maximum": 360,
          "minimum": 0,
          "title": "Mean Anomaly Epoch Deg",
          "type": "number"
        },
        "epoch_year": {
          "default": 0.0,
          "description": "Epoch of orbital elements",
          "title": "Epoch Year",
          "type": "number"
        }
      },
      "required": [
        "body_id",
        "parent_id",
        "semi_major_axis_au",
        "eccentricity"
      ],
      "title": "OrbitalElements",
      "type": "object"
    },
    "Star": {
      "description": "A star in a stellar system.\n\nSupports hybrid input mode: provide either mass, luminosity, or both.\n- mass only: engine computes luminosity, radius, temperature.\n- luminosity only: engine inverts mass-luminosity relation to derive mass,\n  then computes radius and temperature.\n- both: mass takes priority; luminosity is used as override with consistency\n  warning if deviation > 20%.",
      "properties": {
        "id": {
          "description": "Unique identifier within the system, e.g. 'star_sol'",
          "title": "Id",
          "type": "string"
        },
        "name": {
          "description": "Display name of the star",
          "title": "Name",
          "type": "string"
        },
        "spectral_class": {
          "description": "Morgan–Keenan spectral type, e.g. 'G2', 'M1', or coarse 'G', 'M'",
          "title": "Spectral Class",
          "type": "string"
        },
        "luminosity_class": {
          "$ref": "#/$defs/LuminosityClass",
          "default": "V"
        },
        "mass": {
          "anyOf": [
            {
              "description": "Mass in solar masses (M_sun)",
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Stellar mass in M_sun. Required unless luminosity is provided.",
          "title": "Mass"
        },
        "luminosity": {
          "anyOf": [
            {
              "description": "Luminosity in solar luminosities (L_sun)",
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Bolometric luminosity in L_sun. Can be used as alternative input (instead of mass).",
          "title": "Luminosity"
        },
        "temperature": {
          "anyOf": [
            {
              "description": "Temperature in Kelvin",
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Effective surface temperature in K (computed if omitted)",
          "title": "Temperature"
        },
        "radius": {
          "anyOf": [
            {
              "description": "Radius in solar radii (R_sun)",
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Stellar radius in R_sun (computed if omitted)",
          "title": "Radius"
        },
        "metallicity": {
          "default": 0.0,
          "description": "Metallicity [Fe/H] in dex",
          "title": "Metallicity",
          "type": "number"
        },
        "age_gyr": {
          "default": 4.6,
          "description": "Age in gigayears",
          "exclusiveMinimum": 0,
          "title": "Age Gyr",
          "type": "number"
        },
        "position": {
          "$ref": "#/$defs/Vec3",
          "description": "Position in system barycentric frame (AU)"
        }
      },
      "required": [
        "id",
        "name",
        "spectral_class"
      ],
      "title": "Star",
      "type": "object"
    },
    "Vec3": {
      "description": "3D vector in Cartesian coordinates.",
      "properties": {
        "x": {
          "default": 0.0,
          "title": "X",
          "type": "number"
        },
        "y": {
          "default": 0.0,
          "title": "Y",
          "type": "number"
        },
        "z": {
          "default": 0.0,
          "title": "Z",
          "type": "number"
        }
      },
      "title": "Vec3",
      "type": "object"
    }
  },
  "description": "A system of one or more stars and their orbiting bodies.",
  "properties": {
    "name": {
      "description": "Name of the stellar system",
      "title": "Name",
      "type": "string"
    },
    "stars": {
      "description": "Stars in the system",
      "items": {
        "$ref": "#/$defs/Star"
      },
      "minItems": 1,
      "title": "Stars",
      "type": "array"
    },
    "orbits": {
      "description": "Orbital elements for planets and other bodies",
      "items": {
        "$ref": "#/$defs/OrbitalElements"
      },
      "title": "Orbits",
      "type": "array"
    }
  },
  "required": [
    "name",
    "stars"
  ],
  "title": "StellarSystem",
  "type": "object"
}
