{
  "$defs": {
    "StepRecord": {
      "description": "Record of a single computation step in the pipeline.",
      "properties": {
        "engine": {
          "description": "Engine name that ran this step",
          "title": "Engine",
          "type": "string"
        },
        "input_files": {
          "additionalProperties": {
            "type": "string"
          },
          "description": "Mapping of file path -> sha256 checksum",
          "title": "Input Files",
          "type": "object"
        },
        "output_files": {
          "additionalProperties": {
            "type": "string"
          },
          "description": "Mapping of file path -> sha256 checksum",
          "title": "Output Files",
          "type": "object"
        },
        "parameters": {
          "additionalProperties": true,
          "title": "Parameters",
          "type": "object"
        },
        "started": {
          "format": "date-time",
          "title": "Started",
          "type": "string"
        },
        "completed": {
          "format": "date-time",
          "title": "Completed",
          "type": "string"
        },
        "success": {
          "title": "Success",
          "type": "boolean"
        },
        "notes": {
          "default": "",
          "title": "Notes",
          "type": "string"
        }
      },
      "required": [
        "engine",
        "started",
        "completed",
        "success"
      ],
      "title": "StepRecord",
      "type": "object"
    }
  },
  "description": "Tracks the full computation history for a world's derived data.",
  "properties": {
    "world_name": {
      "title": "World Name",
      "type": "string"
    },
    "seed": {
      "title": "Seed",
      "type": "integer"
    },
    "steps": {
      "items": {
        "$ref": "#/$defs/StepRecord"
      },
      "title": "Steps",
      "type": "array"
    },
    "input_checksum": {
      "default": "",
      "description": "Combined checksum of all input files",
      "title": "Input Checksum",
      "type": "string"
    },
    "generated": {
      "format": "date-time",
      "title": "Generated",
      "type": "string"
    },
    "reproducible": {
      "default": true,
      "description": "True if all steps used seeded RNG and deterministic algorithms",
      "title": "Reproducible",
      "type": "boolean"
    }
  },
  "required": [
    "world_name",
    "seed",
    "generated"
  ],
  "title": "ComputationManifest",
  "type": "object"
}
